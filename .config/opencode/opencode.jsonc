{
  "$schema": "https://opencode.ai/config.json",
  // Providers
  "provider": {
    "ollama": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Ollama (minicore)",
      "options": {
        "baseURL": "http://mac-minicore.gerbil-matrix.ts.net:11434/v1",
      },
      "models": {
        "qwen3.5:4b": {
          "name": "Qwen 3.5 4B",
        },
        "qwen3.5": {
          "name": "Qwen 3.5 9B",
        },
        "gpt-oss:latest": {
          "name": "GPT-OSS Latest",
        },
        "nemotron-3-nano:30b-cloud": {
          "name": "Nemotron 3 Nano 30B Cloud",
        },
        "kimi-k2.5:cloud": {
          "name": "Kimi K2.5 Cloud",
        }
      }
    }
  },
  "disabled_providers": ["openai", "mistral", "gemini", "perplexity", "deepseek", "google-vertex-anthropic", "google-vertex"],
  // Preferred models
  // MCP servers
  "mcp": {},
  "autoupdate": true
}

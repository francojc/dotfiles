[general]
status_path = "~/.vdirsyncer/status/"

[pair google_calendar]
a = "google_calendar_local"
b = "google_calendar_remote"
collections = ["from a", "from b"]
conflict_resolution = "b wins"
metadata = ["color", "displayname"]

[storage google_calendar_local]
type = "filesystem"
path = "~/.calendars/google/"
fileext = ".ics"

[storage google_calendar_remote]
type = "google_calendar"
token_file = "~/.vdirsyncer/google_calendar_token"
client_id.fetch = ["command", "pass", "GOOGLE/GOOGLE_CALENDAR_CLIENT"]
client_secret.fetch = ["command", "pass", "GOOGLE/GOOGLE_CALENDAR_SECRET"]
start_date = "datetime.now() - timedelta(days=7)"
end_date = "datetime.now() + timedelta(days=365)"

[pair mailbox_calendar]
a = "mailbox_local"
b = "mailbox_remote"
collections = ["from a", "from b"]
conflict_resolution = "b wins"
metadata = ["color", "displayname"]

[storage mailbox_local]
type = "filesystem"
path = "~/.calendars/mailbox/"
fileext = ".ics"

[storage mailbox_remote]
type = "caldav"
url = "https://dav.mailbox.org/caldav/Y2FsOi8vMC8zMg"
username.fetch = ["command", "pass", "MAILBOX/MAILBOX_USER"]
password.fetch = ["command", "pass", "MAILBOX/MAILBOX_CALDAV_PASSWORD"]
start_date = "datetime.now() - timedelta(days=7)"
end_date = "datetime.now() + timedelta(days=365)"


# Ghostty config

# UI
cursor-color = #FF2557
cursor-style = bar
adjust-cursor-thickness = 2
mouse-hide-while-typing = true
font-size = 15
unfocused-split-opacity = 0.7
split-divider-color = #7B7252
window-padding-x = 9
window-padding-y = 9

# Tabs and windows
window-decoration = none

# Theme
# theme = nightfox
theme = GruvboxDarkHard
# theme = Arthur

# Text
keybind = alt+m=text: |>
keybind = alt+-=text: <-


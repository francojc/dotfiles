{
    "save_workspace": "never",
    "load_workspace": false,
    "pdf_previewer": "system",
    "posix_terminal_shell": "bash",
    "custom_shell_command": "/bin/zsh",
    "remove_history_duplicates": true,
    "highlight_selected_line": true,
    "syntax_color_console": true,
    "auto_save_on_blur": true,
    "default_encoding": "UTF-8",
    "auto_save_on_idle": "commit",
    "show_doc_outline_rmd": true,
    "use_tinytex": true,
    "jobs_tab_visibility": "shown",
    "save_files_before_build": true,
    "document_author": "Jerid Francom",
    "wrap_tab_navigation": false,
    "soft_wrap_r_files": true,
    "default_project_location": "/Users/francojc/Documents/Sandbox/",
    "auto_save_idle_ms": 10000,
    "initial_working_directory": "/Users/francojc/",
    "rainbow_parentheses": true,
    "shiny_viewer_type": "browser",
    "margin_column": 85,
    "rmd_preferred_template_path": "/Users/francojc/R/Library/webexercises/rmarkdown/templates/webexercises",
    "code_completion": "manual",
    "fold_style": "begin-only",
    "rmd_auto_date": true,
    "show_diagnostics_other": true,
    "tab_multiline_completion": true,
    "indent_guides": "rainbowlines",
    "visual_markdown_code_editor_line_numbers": true,
    "default_latex_program": "XeLaTeX",
    "help_font_size_points": 11,
    "font_size_points": 11,
    "show_focus_rectangles": false,
    "insert_native_pipe_operator": true,
    "auto_append_newline": true,
    "strip_trailing_whitespace": true,
    "auto_detect_indentation": true,
    "python_type": "system",
    "python_version": "3.12.3",
    "python_path": "/opt/homebrew/bin/python3",
    "panes": {
        "quadrants": [
            "Source",
            "Console",

#!/usr/bin/env bash
# Monthly review — runs first Sunday of each month at 15:00
# Guard: exit if not in first 7 days of month
set -euo pipefail
source "${HOME}/.bin/pi-cron-common"

LOG_FILE="${LOG_DIR}/monthly-review.log"

main() {
  if [ "$(date +%d)" -gt 7 ]; then
    log_info "Not first week — skipping"
    return 0
  fi
  run_phase "monthly-review-planning" pi_run "monthly-review-planning"
}

if run_job "monthly-review" "$LOG_FILE" main; then
  exit 0
else
  exit $?
fi

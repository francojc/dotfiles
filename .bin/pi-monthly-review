#!/usr/bin/env bash
set -euo pipefail
source "${HOME}/.bin/pi-cron-common"

LOG_FILE="${LOG_DIR}/monthly-review.log"

main() {
  # First-Sunday guard: cron fires every Sunday; exit early if day > 7
  if [ "$(date +%d)" -gt 7 ]; then
    exit 0
  fi
  echo "--- $(date '+%Y-%m-%d %H:%M:%S') ---"
  pi_run "monthly-review-planning"
}

main >> "$LOG_FILE" 2>&1

#!/usr/bin/env bash
#
# ytfp – YouTube Fuzzy Player
# Search YouTube videos interactively with fzf and play them in mpv.
#
# Usage: ytfp [OPTIONS] [QUERY]
#
# Dependencies: curl, chafa, fzf, mpv, yt-dlp
#
# Bookmarking (Ctrl-b) saves the selected video to a Karakeep instance.
# Requires two environment variables:
#   KARAKEEP_API_ADDR  – base URL of your Karakeep instance
#                        (e.g. https://notes.example.com)
#   KARAKEEP_API_KEY   – API key generated in Karakeep under
#                        Settings → API keys
#

set -uo pipefail

# ── Metadata ──────────────────────────────────────────────────────────────────

PROG="ytfp"
VERSION="1.1.0"
DEPS=(curl chafa fzf mpv yt-dlp)
SELF="${BASH_SOURCE[0]}"

# ── Internal functions ────────────────────────────────────────────────────────
# Called by fzf via self-dispatch (avoids relying on export -f in subshells).

_search() {
  local query="${1:-}"
  [[ -z "$query" ]] && return 0
  yt-dlp "ytsearch20:$query" \
    --flat-playlist --print \
    $'%(thumbnails.0.url)s\t%(title)s\t%(channel)s\t%(view_count)s\t%(url)s' \
    2>/dev/null |
    awk -F'\t' '$5 ~ /watch\?v=/' || true
}

_preview() {
  local thumb_url="$1" title="$2" channel="$3" views="$4"
  curl --silent "$thumb_url" | chafa --size=x22 --clear
  printf '%-10s %s\n' 'Title:'   "$title"
  printf '%-10s %s\n' 'Channel:' "$channel"
  printf '%-10s %s\n' 'Views:'   \
    "$(printf '%s' "$views" | awk '{
      n=$0+0; s=""
      while(n>=1000){s=","sprintf("%03d",n%1000)s; n=int(n/1000)}
      print n s
    }')"
}

_bookmark() {
  local url="$1" title="$2"
  local api_addr="${KARAKEEP_API_ADDR:-}"
  local api_key="${KARAKEEP_API_KEY:-}"
  if [[ -z "$api_addr" || -z "$api_key" ]]; then
    printf '%s: KARAKEEP_API_ADDR or KARAKEEP_API_KEY not set\n' "$PROG" >&2
    return 1
  fi
  curl --silent --fail -X POST \
    "$api_addr/api/v1/bookmarks" \
    -H "Authorization: Bearer $api_key" \
    -H "Content-Type: application/json" \
    -d "{\"type\":\"link\",\"url\":\"$url\",\"title\":\"$title\"}" \
    > /dev/null
}

_copy() {
  local url="$1"
  if command -v pbcopy &>/dev/null; then
    printf '%s' "$url" | pbcopy
  elif command -v xclip &>/dev/null; then
    printf '%s' "$url" | xclip -selection clipboard
  elif command -v xsel &>/dev/null; then
    printf '%s' "$url" | xsel --clipboard --input
  else
    printf '%s: no clipboard tool found (pbcopy / xclip / xsel)\n' "$PROG" >&2
    return 1
  fi
}

# ── Self-dispatch (fzf calls this script with a leading __ flag) ──────────────

case "${1:-}" in
  __search)   _search   "${2:-}";            exit ;;
  __preview)  _preview  "$2" "$3" "$4" "$5"; exit ;;
  __bookmark) _bookmark "$2" "$3";           exit ;;
  __copy)     _copy     "$2";               exit ;;
esac

# ── Help / version ────────────────────────────────────────────────────────────

usage() {
  cat <<EOF
Usage: $PROG [OPTIONS] [QUERY]

Search YouTube interactively with fzf and play videos in mpv.

Arguments:
  QUERY              Optional initial search query (quote multi-word queries)

Options:
  -a, --audio        Play audio only (no video)
  -h, --help         Show this help message and exit
  -v, --version      Show version and exit

Key bindings (inside fzf):
  Enter              Play selected video (fullscreen)
  Ctrl-a             Play selected video audio only
  Ctrl-b             Bookmark video to Karakeep
  Ctrl-y             Copy video URL to clipboard
  Esc / Ctrl-c       Quit

Dependencies: ${DEPS[*]}

Examples:
  $PROG                        Start with an empty search
  $PROG "lofi hip hop"         Start with an initial query
  $PROG -a "jazz piano"        Start in audio-only mode
EOF
}

version() {
  echo "$PROG $VERSION"
}

# ── Dependency check ──────────────────────────────────────────────────────────

check_deps() {
  local missing=()
  for dep in "${DEPS[@]}"; do
    command -v "$dep" &>/dev/null || missing+=("$dep")
  done
  if [[ ${#missing[@]} -gt 0 ]]; then
    printf '%s: missing required tools: %s\n' "$PROG" "${missing[*]}" >&2
    printf 'Install them and try again.\n' >&2
    exit 1
  fi
}

# ── Argument parsing ──────────────────────────────────────────────────────────

AUDIO_ONLY=false
INITIAL_QUERY=""

while [[ $# -gt 0 ]]; do
  case "$1" in
    -a | --audio)   AUDIO_ONLY=true;          shift ;;
    -h | --help)    usage;                    exit 0 ;;
    -v | --version) version;                  exit 0 ;;
    --)             shift; INITIAL_QUERY="$*"; break ;;
    -*)
      printf '%s: unknown option: %s\n\n' "$PROG" "$1" >&2
      usage >&2
      exit 1
      ;;
    *) INITIAL_QUERY="$*"; break ;;
  esac
done

# ── Main ──────────────────────────────────────────────────────────────────────

check_deps

if [[ "$AUDIO_ONLY" == true ]]; then
  PLAY_CMD="mpv --no-video {5}"
  MODE_LABEL=" [audio-only] "
else
  PLAY_CMD="mpv --fullscreen {5}"
  MODE_LABEL=" "
fi

HEADER="${MODE_LABEL}Enter:play  Ctrl-a:audio  Ctrl-b:bookmark  Ctrl-y:copy-url  Esc:quit"

fzf \
  --preview-window down:65% \
  --layout reverse \
  --disabled \
  --with-shell 'bash -c' \
  --query "$INITIAL_QUERY" \
  --header "$HEADER" \
  --bind "start:reload:\"$SELF\" __search {q} || true" \
  --bind "change:reload:sleep 0.3; \"$SELF\" __search {q} || true" \
  --bind "load:first" \
  --delimiter $'\t' \
  --with-nth 2 \
  --preview "\"$SELF\" __preview {1} {2} {3} {4}" \
  --bind "enter:execute-silent($PLAY_CMD)" \
  --bind "ctrl-a:execute-silent(mpv --no-video {5})" \
  --bind "ctrl-b:execute-silent(\"$SELF\" __bookmark {5} {2})" \
  --bind "ctrl-y:execute-silent(\"$SELF\" __copy {5})+abort"

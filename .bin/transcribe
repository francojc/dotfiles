#!/usr/bin/env -S nix-shell --pure
#!nix-shell -i python3 -p "python3.withPackages(ps: with ps; [ openai ])"

import argparse
import os
from pathlib import Path
from openai import OpenAI


def validate_file(file_path: str) -> None:
    """Validates if the audio file meets the requirements for OpenAI transcription.

    Args:
        file_path (str): Path to the audio file to be validated.

    Raises:
        FileNotFoundError: If the specified file does not exist.
        ValueError: If the file type is not supported or file size exceeds limit.
    """
    path = Path(file_path)
    if not path.exists():
        raise FileNotFoundError(f"File not found: {file_path}")

    valid_extensions = {".mp3", ".mp4", ".mpeg", ".mpga", ".m4a", ".wav", ".webm"}
    if path.suffix.lower() not in valid_extensions:
        raise ValueError(
            f"Unsupported file type. Supported types: {', '.join(valid_extensions)}"
        )

    # 25MB in bytes
    if path.stat().st_size > 25 * 1024 * 1024:
        raise ValueError("File size exceeds 25MB limit")


def main() -> None:
    """Main function to handle audio transcription workflow.

    Processes command line arguments, validates the input file,
    transcribes the audio using OpenAI's Whisper model, and saves
    the transcription to a text file.

    Environment Variables:
        OPENAI_API_KEY: Required API key for OpenAI services.

    Returns:
        None

    Exits:
        0: Successful execution
        1: Error occurred during execution
    """
    parser = argparse.ArgumentParser(
        description="Transcribe an audio file using OpenAI (Whisper-1). File uploads are currently limited to 25 MB and the following input file types are supported: mp3, mp4, mpeg, mpga, m4a, wav, and webm."
    )
    parser.add_argument("file_path", type=str, help="Path to the audio file")
    args = parser.parse_args()

    api_key = os.getenv("OPENAI_API_KEY")
    if not api_key:
        raise ValueError("OPENAI_API_KEY environment variable is not set")

    client = OpenAI(api_key=api_key)

    try:
        validate_file(args.file_path)

        with open(args.file_path, "rb") as audio_file:
            transcript = client.audio.transcriptions.create(
                model="whisper-1", file=audio_file, response_format="text"
            )

        output_path = os.path.splitext(args.file_path)[0] + ".txt"
        with open(output_path, "w") as file:
            file.write(transcript)

        print(f"Transcription saved to: {output_path}")

    except Exception as e:
        print(f"Error: {str(e)}")
        exit(1)


if __name__ == "__main__":
    main()

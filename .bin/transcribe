#!/usr/bin/env bash

# transcribe: Transcribe an audio file using OpenAI's Whisper
# Usage: transcribe -f FILE_PATH
# Example: transcribe -f "audio.mp3"

set -euo pipefail

# Validate dependencies
command -v curl >/dev/null 2>&1 || { echo "Error: curl is required"; exit 1; }
command -v jq >/dev/null 2>&1 || { echo "Error: jq is required"; exit 1; }

# Parse arguments
while getopts ":hf:" opt; do
  case $opt in
    h)
      echo "Usage: $0 [-h] -f FILE_PATH"
      echo "Transcribe an audio file using OpenAI Whisper-1"
      echo "Supported formats: mp3, mp4, mpeg, mpga, m4a, wav, webm"
      exit 0
      ;;
    f)
      file_path="$OPTARG"
      ;;
    \?)
      echo "Invalid option: -$OPTARG" >&2
      exit 1
      ;;
  esac
done

# Validate file exists
if [[ ! -f "$file_path" ]]; then
  echo "Error: File not found: $file_path" >&2
  exit 1
fi

# Generate output filename
output_file="${file_path%.*}.txt"

# Call OpenAI API
response=$(curl -s https://api.openai.com/v1/audio/transcriptions \
  -H "Authorization: Bearer $OPENAI_API_KEY" \
  -H "Content-Type: multipart/form-data" \
  -F file="@$file_path" \
  -F model="whisper-1" \
  -F response_format="text")

# Check for API errors
if [[ $(jq -r '.error.message' <<< "$response" 2>/dev/null) != "null" ]]; then
  echo "API Error: $(jq -r '.error.message' <<< "$response")" >&2
  exit 1
fi

# Save response
echo "$response" > "$output_file"
echo "Transcript saved to: $output_file"

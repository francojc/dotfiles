#!/usr/bin/env bash
# Auto-ingest pipeline — sync Karakeep bookmarks then batch-ingest new sources
# Chain: karakeep-sync.sh → detect new files → wiki-batch-ingest

set -euo pipefail
source "${HOME}/.bin/common"

SCRIPT_DIR="${HOME}/Obsidian/Notes/.pi/skills/_shared/scripts"
VAULT_DIR="${HOME}/Obsidian/Notes"
WEB_DIR="${VAULT_DIR}/kb/sources/web"
LOG_FILE="${VAULT_DIR}/.claude/logs/karakeep-to-wiki.log"
LAST_SYNC_FILE="${VAULT_DIR}/.credentials/karakeep-last-sync"

main() {
  echo "--- $(date '+%Y-%m-%d %H:%M:%S') ---"

  # Step 1: Sync Karakeep bookmarks
  log_info "Step 1: Syncing Karakeep bookmarks..."
  bash "$SCRIPT_DIR/karakeep-sync.sh" >> "$LOG_FILE" 2>&1
  if [ $? -ne 0 ]; then
    log_error "karakeep-sync.sh failed"
    return 1
  fi

  # Step 2: Get new files since last sync
  log_info "Step 2: Detecting new files..."
  if [ ! -f "$LAST_SYNC_FILE" ]; then
    log_info "No last-sync file — skipping ingest (first run?)"
    return 0
  fi

  local last_sync
  last_sync=$(cat "$LAST_SYNC_FILE")
  local last_sync_unix
  last_sync_unix=$(date -j -f "%Y-%m-%dT%H:%M:%S.%NZ" "${last_sync}" +%s 2>/dev/null || echo "0")

  # Find markdown files in kb/sources/web/ modified after last_sync
  local new_files=()
  while IFS= read -r file; do
    local file_mtime
    file_mtime=$(stat -f %m "$file" 2>/dev/null || stat -c %Y "$file" 2>/dev/null || echo "0")
    if [ "$file_mtime" -gt "$last_sync_unix" ]; then
      new_files+=("$file")
    fi
  done < <(find "$WEB_DIR" -name "*.md" -type f 2>/dev/null | grep -v attachments)

  if [ ${#new_files[@]} -eq 0 ]; then
    log_info "No new files to ingest"
    return 0
  fi

  log_info "Found ${#new_files[@]} new files to ingest"
  echo "New files: ${new_files[*]}" >> "$LOG_FILE"

  # Step 3: Batch-ingest the new files
  log_info "Step 3: Batch-ingesting ${#new_files[@]} sources..."
  local file_list
  file_list=$(printf '"%s" ' "${new_files[@]}")
  claude -p "/skill:wiki-batch-ingest ${file_list}" \
    --dangerously-skip-permissions \
    --strict-mcp-config \
    >> "$LOG_FILE" 2>&1

  log_info "Auto-ingest pipeline complete"
}

main >> "$LOG_FILE" 2>&1
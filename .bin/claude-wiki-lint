#!/usr/bin/env bash
# Wiki lint — health check the LLM Wiki
# Runs weekly (before weekly-planning)

set -euo pipefail
source "${HOME}/.bin/claude-cron-common"

LOG_FILE="${LOG_DIR}/wiki-lint.log"

main() {
  echo "--- $(date '+%Y-%m-%d %H:%M:%S') ---"
  claude_run "/skill:wiki-lint"
}

main >> "$LOG_FILE" 2>&1
#!/usr/bin/env bash
# Wiki lint — Sundays at 17:30 (before weekly-planning)
set -euo pipefail
source "${HOME}/.bin/pi-cron-common"

LOG_FILE="${LOG_DIR}/wiki-lint.log"

main() {
  run_phase "wiki-lint --fix" pi_run "wiki-lint" "--fix"
}

if run_job "wiki-lint" "$LOG_FILE" main; then
  exit 0
else
  exit $?
fi

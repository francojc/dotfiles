      WX_ICON="⛈"  WX_COLOR="$BR_MAGENTA" WX_DESC="Thunderstorm with Hail"
      WX_SNARKS=(
        "Thunderstorm with hail. The sky is throwing a tantrum AND throwing rocks."
        "Hail and lightning. Nature is actively dunking on your car's resale value."
        "Thunderstorm with hail. The sky has completely lost the plot."
        "Hailstones and lightning. Weather as personal attack."
        "Hail. The sky is not satisfied with just being wet and loud."
        "Thunderstorm with hail. Everything outside is having a bad time."
        "Ice from the sky, lightning from the sky. The sky is everything right now."
        "Hail-producing thunderstorm. Your patio furniture is on its own."
      ) ;;
    99)
      WX_ICON="⛈"  WX_COLOR="$RED" WX_DESC="Thunderstorm, Heavy Hail"
      WX_SNARKS=(
        "Thunderstorm with heavy hail. Your insurance agent is preemptively weeping."
        "The sky is done pretending to be nice. Seek shelter immediately."
        "Heavy hail and lightning. This is not a drill. Go inside. Now."
        "Large hail and severe lightning. The atmosphere has escalated to threats."
        "Heavy hail. Anything parked outside is a science experiment now."
        "This is the kind of weather that ends up in news reports. Stay inside."
        "Severe thunderstorm with large hail. The sky has declared war on your possessions."
      ) ;;
    *)
      WX_ICON="?" WX_COLOR="$GRAY" WX_DESC="Weather Code ${WX_CODE}"
      WX_SNARKS=(
        "Weather code ${WX_CODE}? Even the meteorologists are confused. Good luck."
        "Unknown forecast. As opaque as most things in life, honestly."
        "The forecast is unprecedented. Just like everything else lately."
        "Unclassified weather. Dress in layers and hope for the best."
      ) ;;
  esac

  local n=${#WX_SNARKS[@]}
  WX_SNARK="${WX_SNARKS[$(( RANDOM % n ))]}"
}

# ─── Temperature comment ───────────────────────────────────────────────────────
temp_comment() {
  local t; t=$(printf '%.0f' "$TEMP_MAX")
  if   (( t <=   0 )); then TEMP_COMMENT="Dangerously cold. You are not a penguin."
  elif (( t <=  20 )); then TEMP_COMMENT="Brutal. Reconsider every one of your choices."
  elif (( t <=  32 )); then TEMP_COMMENT="Freezing. Layer up like your life depends on it."
  elif (( t <=  45 )); then TEMP_COMMENT="Cold and raw. A jacket is non-negotiable."
  elif (( t <=  55 )); then TEMP_COMMENT="Crisp and cool. Hoodie weather. No notes."
  elif (( t <=  65 )); then TEMP_COMMENT="Pleasantly mild. Suspicious, honestly."
  elif (( t <=  75 )); then TEMP_COMMENT="Lovely. Don't ruin it by staying indoors all day."
  elif (( t <=  85 )); then TEMP_COMMENT="Warm. Make shade your best friend."
  elif (( t <=  95 )); then TEMP_COMMENT="Hot. Hydrate aggressively or suffer."
  elif (( t <= 105 )); then TEMP_COMMENT="Very hot. The asphalt is cooking and so are you."
  else                      TEMP_COMMENT="Dangerously hot. The sun has filed a formal complaint."
  fi
}

# ─── Wind comment ──────────────────────────────────────────────────────────────
wind_comment() {
  local w; w=$(printf '%.0f' "$WIND")
  if   (( w <=  5 )); then WIND_COMMENT="Dead calm. Enjoy it."
  elif (( w <= 12 )); then WIND_COMMENT="Light breeze. Nothing to worry about."
  elif (( w <= 20 )); then WIND_COMMENT="Moderate wind. Hold onto your hat."
  elif (( w <= 30 )); then WIND_COMMENT="Breezy enough to reconsider your hairstyle choices."
  elif (( w <= 40 )); then WIND_COMMENT="Strong winds. Umbrellas will not survive this."
  elif (( w <= 55 )); then WIND_COMMENT="Very strong. You'll walk at a 45-degree angle."
  else                     WIND_COMMENT="You may become briefly airborne. Not a joke."
  fi
}

# ─── Precipitation comment ─────────────────────────────────────────────────────
precip_comment() {
  local p; p=$(printf '%.0f' "$PRECIP")
  if   (( p <= 10 )); then PRECIP_COMMENT="Basically bone dry."
  elif (( p <= 30 )); then PRECIP_COMMENT="Low chance. Gamble on leaving the umbrella home."
  elif (( p <= 50 )); then PRECIP_COMMENT="Coin flip. Pack it — you'll regret not packing it."
  elif (( p <= 70 )); then PRECIP_COMMENT="More likely wet than not. Bring rain gear."
  elif (( p <= 90 )); then PRECIP_COMMENT="Very likely. Just accept the moisture."
  else                     PRECIP_COMMENT="Basically guaranteed. You WILL be wet."
  fi
}

# ─── Run all lookups ───────────────────────────────────────────────────────────
wx_lookup
temp_comment
wind_comment
precip_comment

# ─── Drawing helpers ───────────────────────────────────────────────────────────
COLS=$(tput cols 2>/dev/null || echo 72)
(( COLS > 80 )) && COLS=80

draw_rule() {
  local char="${1:-─}" pad=2
  local n=$(( COLS - pad ))
  local line=""
  for (( i = 0; i < n; i++ )); do line+="$char"; done
  printf "  %s\n" "$line"
}

SEP="  ${DIM}·${RESET}  "

# ─── Render ────────────────────────────────────────────────────────────────────
WX_DESC_UPPER=$(printf '%s' "$WX_DESC" | tr '[:lower:]' '[:upper:]')

if $LINE; then

  # ── Single-line mode ─────────────────────────────────────────────────────────
  printf "${BOLD}${WX_COLOR}%s %s${RESET}" "$WX_ICON" "$WX_DESC_UPPER"
  printf "$SEP"
  printf "${BOLD}${ORANGE}↑%.0f°F${RESET} ${BOLD}${BR_CYAN}↓%.0f°F${RESET}" "$TEMP_MAX" "$TEMP_MIN"
  printf "$SEP"
  printf "${BOLD}${BLUE}%.0f%% rain${RESET}" "$PRECIP"
  printf "$SEP"
  printf "${BOLD}${CYAN}%.0f mph${RESET}" "$WIND"
  printf '\n'
  printf "  ${ITALIC}${DIM}\"%s\"${RESET}\n" "$WX_SNARK"

else

  # ── Full mode ────────────────────────────────────────────────────────────────
  printf '\n'

  # Header
  printf "  ${BOLD}${WX_COLOR}%s  SKYSNARK${RESET}" "$WX_ICON"
  printf "$SEP"
  printf "${BOLD}${WHITE}%s${RESET}" "$DISPLAY_LOC"
  printf "$SEP"
  printf "${LIGHT_GRAY}%s${RESET}\n" "$DISPLAY_DATE"
  draw_rule "─"

  printf '\n'

  # Condition label
  printf "  ${BOLD}${WX_COLOR}%s  %s${RESET}\n" "$WX_ICON" "$WX_DESC_UPPER"

  printf '\n'

  # Stats block
  printf "  ${GRAY}%-16s${RESET}" "Temperature"
  printf "  ${BOLD}${ORANGE}↑ %.0f°F${RESET}" "$TEMP_MAX"
  printf "  ${BOLD}${BR_CYAN}↓ %.0f°F${RESET}" "$TEMP_MIN"
  printf "  ${DIM}%s${RESET}\n" "$TEMP_COMMENT"

  printf "  ${GRAY}%-16s${RESET}" "Precipitation"
  printf "  ${BOLD}${BLUE}%s%%${RESET}" "$PRECIP"
  printf "  ${DIM}%s${RESET}\n" "$PRECIP_COMMENT"

  printf "  ${GRAY}%-16s${RESET}" "Wind"
  printf "  ${BOLD}${CYAN}%.0f mph${RESET}" "$WIND"
  printf "  ${DIM}%s${RESET}\n" "$WIND_COMMENT"

  printf "  ${GRAY}%-16s${RESET}" "Sunshine"
  printf "  ${BOLD}${BR_YELLOW}%s hrs${RESET}\n" "$SUN_HRS"

  printf '\n'
  draw_rule "╌"
  printf '\n'

  # Snark
  printf "  ${ITALIC}${DIM}\"${WX_SNARK}\"${RESET}\n"
  printf '\n'

fi

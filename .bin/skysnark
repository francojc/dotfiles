#!/usr/bin/env bash
# skysnark — weather forecast with attitude
# Usage: skysnark --location "City, ST" [--date YYYY-MM-DD]

set -euo pipefail

# ─── ANSI ──────────────────────────────────────────────────────────────────────
# Only emit color codes when stdout is an interactive terminal. When piped or
# captured (e.g. :read ! in Neovim), all variables are empty and plain text
# is written instead.
if [ -t 1 ]; then
  RESET='\033[0m'
  BOLD='\033[1m'
  DIM='\033[2m'
  ITALIC='\033[3m'
  RED='\033[31m'
  YELLOW='\033[33m'
  BLUE='\033[34m'
  MAGENTA='\033[35m'
  CYAN='\033[36m'
  WHITE='\033[37m'
  BR_YELLOW='\033[93m'
  BR_BLUE='\033[94m'
  BR_MAGENTA='\033[95m'
  BR_CYAN='\033[96m'
  ORANGE='\033[38;5;208m'
  GRAY='\033[38;5;245m'
  LIGHT_GRAY='\033[38;5;250m'
else
  RESET='' BOLD='' DIM='' ITALIC='' RED='' YELLOW='' BLUE='' MAGENTA=''
  CYAN='' WHITE='' BR_YELLOW='' BR_BLUE='' BR_MAGENTA='' BR_CYAN=''
  ORANGE='' GRAY='' LIGHT_GRAY=''
fi

# ─── Dependencies ──────────────────────────────────────────────────────────────
for dep in curl jq awk; do
  command -v "$dep" &>/dev/null || {
    printf "Error: '%s' is required but not installed.\n" "$dep" >&2
    exit 1
  }
done

# ─── Usage ─────────────────────────────────────────────────────────────────────
usage() {
  printf "\n${BOLD}skysnark${RESET} — weather forecast with attitude\n\n"
  printf "${BOLD}Usage:${RESET}\n"
  printf "  skysnark --location <place> [--date <YYYY-MM-DD>]\n\n"
  printf "${BOLD}Options:${RESET}\n"
  printf "  %-28s %s\n" "--location <place>"    "City name or address (required)"
  printf "  %-28s %s\n" "--date <YYYY-MM-DD>"   "Forecast date (default: today, max 7 days ahead)"
  printf "  %-28s %s\n" "--line"                "Condense output to a single line"
  printf "  %-28s %s\n" "--help"                "Show this help message"
  printf "\n${BOLD}Examples:${RESET}\n"
  printf "  skysnark --location \"Winston-Salem, NC\"\n"
  printf "  skysnark --location \"Tokyo\" --date 2025-04-01\n\n"
  exit 0
}

# ─── Arguments ─────────────────────────────────────────────────────────────────
LOCATION=""
DATE=""
LINE=false

while [[ $# -gt 0 ]]; do
  case "$1" in
    --location) LOCATION="$2"; shift 2 ;;
    --date)     DATE="$2";     shift 2 ;;
    --line)     LINE=true;     shift   ;;
    --help|-h)  usage ;;
    *)
      printf "${RED}Error:${RESET} Unknown argument: %s\n\n" "$1" >&2
      usage
      ;;
  esac
done

[[ -z "$LOCATION" ]] && {
  printf "${RED}Error:${RESET} --location is required.\n\n" >&2
  usage
}

TODAY=$(date +%Y-%m-%d)
[[ -z "$DATE" ]] && DATE="$TODAY"

[[ "$DATE" =~ ^[0-9]{4}-[0-9]{2}-[0-9]{2}$ ]] || {
  printf "${RED}Error:${RESET} --date must be in YYYY-MM-DD format.\n" >&2
  exit 1
}

[[ "$DATE" < "$TODAY" ]] && {
  printf "${RED}Error:${RESET} Date cannot be in the past.\n" >&2
  exit 1
}

# Cross-platform "+7 days"
if date -v+7d +%Y-%m-%d &>/dev/null 2>&1; then
  MAX_DATE=$(date -v+7d +%Y-%m-%d)          # macOS BSD date
else
  MAX_DATE=$(date -d "+7 days" +%Y-%m-%d)   # GNU date
fi

[[ "$DATE" > "$MAX_DATE" ]] && {
  printf "${RED}Error:${RESET} Date must be within 7 days (max: %s).\n" "$MAX_DATE" >&2
  exit 1
}

# ─── Progress helper ───────────────────────────────────────────────────────────
# Suppress spinner entirely when stdout is not a TTY (piped, :read !, etc.)
if [ -t 1 ]; then
  progress()       { printf "  ${DIM}%s...${RESET}\033[K\r" "$1" >&2; }
  clear_progress() { printf '\r\033[K' >&2; }
else
  progress()       { :; }
  clear_progress() { :; }
fi

# ─── Geocoding ─────────────────────────────────────────────────────────────────
progress "Locating $LOCATION"

# The Open-Meteo geocoding API only understands plain city names, not "City, State"
# Strip anything after a comma so "Winston-Salem, NC" becomes "Winston-Salem"
LOC_QUERY="${LOCATION%%,*}"
LOC_ENC=$(printf '%s' "$LOC_QUERY" | jq -sRr @uri)
GEO_JSON=$(curl -sf \
  "https://geocoding-api.open-meteo.com/v1/search?name=${LOC_ENC}&count=1&language=en&format=json") || {
  clear_progress
  printf "${RED}Error:${RESET} Could not reach geocoding API. Check your connection.\n" >&2
  exit 1
}

COUNT=$(printf '%s' "$GEO_JSON" | jq '.results | length // 0')
(( COUNT > 0 )) || {
  clear_progress
  printf "${RED}Error:${RESET} Location not found: \"%s\"\n" "$LOCATION" >&2
  exit 1
}

LAT=$(printf '%s' "$GEO_JSON"      | jq -r '.results[0].latitude')
LON=$(printf '%s' "$GEO_JSON"      | jq -r '.results[0].longitude')
CITY=$(printf '%s' "$GEO_JSON"     | jq -r '.results[0].name')
ADMIN=$(printf '%s' "$GEO_JSON"    | jq -r '.results[0].admin1 // ""')
COUNTRY=$(printf '%s' "$GEO_JSON"  | jq -r '.results[0].country // ""')
TIMEZONE=$(printf '%s' "$GEO_JSON" | jq -r '.results[0].timezone // "UTC"')

[[ -n "$ADMIN" ]] \
  && DISPLAY_LOC="${CITY}, ${ADMIN}" \
  || DISPLAY_LOC="${CITY}, ${COUNTRY}"

# ─── Weather API ───────────────────────────────────────────────────────────────
progress "Fetching forecast for $DISPLAY_LOC"

TZ_ENC=$(printf '%s' "$TIMEZONE" | jq -sRr @uri)
WX_URL="https://api.open-meteo.com/v1/forecast"
WX_URL+="?latitude=${LAT}&longitude=${LON}"
WX_URL+="&daily=apparent_temperature_max,apparent_temperature_min"
WX_URL+=",weather_code,precipitation_probability_max"
WX_URL+=",wind_speed_10m_max,sunshine_duration"
WX_URL+="&timezone=${TZ_ENC}"
WX_URL+="&wind_speed_unit=mph"
WX_URL+="&temperature_unit=fahrenheit"
WX_URL+="&precipitation_unit=inch"

WX_JSON=$(curl -sf "$WX_URL") || {
  clear_progress
  printf "${RED}Error:${RESET} Could not reach weather API. Check your connection.\n" >&2
  exit 1
}

# ─── Extract data for the requested date ───────────────────────────────────────
IDX=$(printf '%s' "$WX_JSON" | jq -r --arg d "$DATE" '
  (.daily.time | to_entries[] | select(.value == $d).key) // empty
' | head -1)

[[ -z "$IDX" ]] && {
  clear_progress
  printf "${RED}Error:${RESET} No forecast data available for %s.\n" "$DATE" >&2
  exit 1
}

TEMP_MAX=$(printf '%s' "$WX_JSON" | jq -r --argjson i "$IDX" '.daily.apparent_temperature_max[$i] // "N/A"')
TEMP_MIN=$(printf '%s' "$WX_JSON" | jq -r --argjson i "$IDX" '.daily.apparent_temperature_min[$i] // "N/A"')
WX_CODE=$(printf '%s' "$WX_JSON"  | jq -r --argjson i "$IDX" '.daily.weather_code[$i] // 0')
PRECIP=$(printf '%s' "$WX_JSON"   | jq -r --argjson i "$IDX" '.daily.precipitation_probability_max[$i] // 0')
WIND=$(printf '%s' "$WX_JSON"     | jq -r --argjson i "$IDX" '.daily.wind_speed_10m_max[$i] // 0')
SUN_SEC=$(printf '%s' "$WX_JSON"  | jq -r --argjson i "$IDX" '.daily.sunshine_duration[$i] // 0')
SUN_HRS=$(awk "BEGIN { printf \"%.1f\", $SUN_SEC / 3600 }")

clear_progress

# Format display date (cross-platform)
if date -j -f "%Y-%m-%d" "$DATE" "+%A, %B %-d, %Y" &>/dev/null 2>&1; then
  DISPLAY_DATE=$(date -j -f "%Y-%m-%d" "$DATE" "+%A, %B %-d, %Y")   # macOS
else
  DISPLAY_DATE=$(date -d "$DATE" "+%A, %B %-d, %Y")                  # Linux
fi


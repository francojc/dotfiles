#!/usr/bin/env bash
# Yearly vision + planning — runs December 15 at 10:00
set -euo pipefail
source "${HOME}/.bin/pi-cron-common"

LOG_FILE="${LOG_DIR}/yearly-planning.log"

main() {
  run_phase "vision-yearly-planning" pi_run "vision-yearly-planning"
}

if run_job "yearly-planning" "$LOG_FILE" main; then
  exit 0
else
  exit $?
fi

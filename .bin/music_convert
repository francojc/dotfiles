#!/usr/bin/env bash
# music_convert — Process Apple Music exports into a portable library.
#
# File handling:
#   .mp4 / .m4a  — lossy Apple formats; transcoded to lossless FLAC
#   .mp3         — already a portable format; copied as-is, no re-encoding
#   .m4p         — DRM-protected; skipped with warning by default
#                  use --divert-m4p to move them to ~/Desktop/m4ps/ for manual handling
#
# Source path convention (trailing slash matters):
#   music_convert ~/Music/Artist/   ~/FLAC/   # trailing slash: contents go into target
#                                             # → ~/FLAC/Album/track.flac
#   music_convert ~/Music/Artist    ~/FLAC/   # no trailing slash: dir itself goes in
#                                             # → ~/FLAC/Artist/Album/track.flac
#
# Usage: music_convert [--dry-run] [--divert-m4p] [--help] <source_dir> <target_dir>

set -euo pipefail

# ---------------------------------------------------------------------------
# Constants
# ---------------------------------------------------------------------------
LOG_DIR="$HOME/.local/share/music_convert"
LOG_FILE="$LOG_DIR/music_convert.log"
M4P_DIR="$HOME/Desktop/m4ps"

# ---------------------------------------------------------------------------
# Logging
# ---------------------------------------------------------------------------
log() {
  local level="$1"
  local msg="$2"
  local ts
  ts=$(date '+%Y-%m-%d %H:%M:%S')
  printf '[%s] [%-7s] %s\n' "$ts" "$level" "$msg" >> "$LOG_FILE"
}

# ---------------------------------------------------------------------------
# Usage
# ---------------------------------------------------------------------------
usage() {
  cat <<'EOF'
Usage: music_convert [--dry-run] [--divert-m4p] [--help] <source_dir> <target_dir>

Convert Apple Music files, mirroring the source directory structure under
the target directory.

  .mp4 / .m4a  →  converted to .flac
  .mp3         →  copied as-is (no re-encoding)
  .m4p         →  skipped with warning (DRM-protected; see --divert-m4p)

Arguments:
  source_dir   Directory containing audio files (must exist)
  target_dir   Destination root for output (must exist)

Flags:
  --dry-run    Show what would be done without doing anything
  --divert-m4p     Move .m4p files to ~/Desktop/m4ps/ (preserving Artist/Album
               structure) instead of skipping them. Use this to collect
               DRM-protected files for manual handling (e.g., burn-and-rip).
  --help       Show this help message

Examples:
  music_convert ~/Music/Apple\ Music ~/Music/FLAC
  music_convert --divert-m4p ~/Music/Apple\ Music ~/Music/FLAC
  music_convert --dry-run /Volumes/Purchases ~/NAS/music

Notes:
  - Trailing slash on source_dir controls output structure (rsync convention):
      music_convert ~/Music/Artist/  ~/FLAC/  # contents into target (no Artist/ wrapper)
      music_convert ~/Music/Artist   ~/FLAC/  # Artist/ dir created inside target
      music_convert ~/Music/         ~/FLAC/  # each Artist/ subdir placed inside target
  - .mp3 files are copied without re-encoding (already portable)
  - .mp4/.m4a files are transcoded to FLAC (lossless)
  - .m4p files are DRM-protected and cannot be decoded by ffmpeg; they are
    skipped by default. Use --divert-m4p to move them to ~/Desktop/m4ps/ so
    they can be handled separately (e.g., via iTunes burn-and-rip workflow).
  - Skips files that already exist at the target path
  - Skips .mp4/.m4a files with no audio stream
  - Logs all activity to ~/.local/share/music_convert/music_convert.log
  - ffmpeg, ffprobe, and fd must be on PATH

Conversion flags used:
  ffmpeg -i <src> -vn -acodec flac -compression_level 12 -map_metadata 0
EOF
}

# ---------------------------------------------------------------------------
# Argument parsing
# ---------------------------------------------------------------------------
dry_run=false
divert_m4p=false
positional=()

for arg in "$@"; do
  case "$arg" in
    --help|-h) usage; exit 0 ;;
    --dry-run) dry_run=true ;;
    --divert-m4p)  divert_m4p=true ;;
    -*) printf 'Unknown flag: %s\n' "$arg" >&2; usage >&2; exit 1 ;;
    *) positional+=("$arg") ;;
  esac
done

if [[ ${#positional[@]} -ne 2 ]]; then
  printf 'Error: expected 2 positional arguments, got %d\n' \
    "${#positional[@]}" >&2
  usage >&2
  exit 1
fi

# Trailing slash on source → strip src base from output paths (rsync convention:
# "copy contents", not "copy the directory itself").
[[ "${positional[0]}" == */ ]] && strip_base=true || strip_base=false

src="${positional[0]%/}"
tgt="${positional[1]%/}"

if [[ "$strip_base" == true ]]; then
  tgt_base="$tgt"
else
  tgt_base="$tgt/$(basename "$src")"
fi

# ---------------------------------------------------------------------------
# Validate inputs
# ---------------------------------------------------------------------------
if [[ ! -d "$src" ]]; then
  printf 'Error: source directory does not exist: %s\n' "$src" >&2
  exit 1
fi

if [[ ! -d "$tgt" ]]; then
  printf 'Error: target directory does not exist: %s\n' "$tgt" >&2
  exit 1
fi

# ---------------------------------------------------------------------------
# Dependency check
# ---------------------------------------------------------------------------
missing=()
for cmd in ffmpeg ffprobe fd; do
  command -v "$cmd" &>/dev/null || missing+=("$cmd")
done

if [[ ${#missing[@]} -gt 0 ]]; then
  printf 'Error: required tool(s) not found on PATH: %s\n' \
    "${missing[*]}" >&2
  printf '\nInstall via Homebrew:\n' >&2
  printf '  brew install ffmpeg\n' >&2
  printf '\nOr via Nix:\n' >&2
  printf '  nix profile install nixpkgs#ffmpeg\n' >&2
  exit 1
fi

# ---------------------------------------------------------------------------
# Setup log directory
# ---------------------------------------------------------------------------
mkdir -p "$LOG_DIR"

# ---------------------------------------------------------------------------
# Collect files (bash 3.x-compatible two-pass approach)
# ---------------------------------------------------------------------------
files=()
while IFS= read -r -d '' f; do
  files+=("$f")
done < <(fd -e mp4 -e m4p -e m4a -e mp3 -t f -0 . "$src" | sort -z)

total=${#files[@]}

if [[ $total -eq 0 ]]; then
  printf 'No .mp4/.m4p/.m4a/.mp3 files found under %s\n' "$src"
  exit 0
fi

# ---------------------------------------------------------------------------
# Run start
# ---------------------------------------------------------------------------
log INFO "Run started — source: $src  target: $tgt  dry_run: $dry_run  divert_m4p: $divert_m4p"
printf 'Found %d file(s) (.mp4/.m4p/.m4a/.mp3) under %s\n\n' "$total" "$src"

converted=0
copied=0
diverted=0
skipped=0
errors=0
count=0

# ---------------------------------------------------------------------------
# Main loop
# ---------------------------------------------------------------------------
for src_file in "${files[@]}"; do
  count=$((count + 1))
  rel="${src_file#"$src"/}"
  ext="${src_file##*.}"
  out_dir="$tgt_base/$(dirname "$rel")"

  prefix="[$count/$total]"

  case "$ext" in
    mp3)
      # .mp3: copy as-is
      out="$tgt_base/$rel"

      if [[ -f "$out" ]]; then
        printf '%s SKIP (exists)  %s\n' "$prefix" "$out"
        log SKIP "Already exists: $out"
        skipped=$((skipped + 1))
        continue
      fi

      printf '%s COPY     %s\n        -> %s\n' "$prefix" "$src_file" "$out"

      if [[ "$dry_run" == true ]]; then
        log INFO "Dry-run copy: $src_file -> $out"
        copied=$((copied + 1))
        continue
      fi

      mkdir -p "$out_dir"

      if cp "$src_file" "$out"; then
        log OK "Copied: $src_file -> $out"
        copied=$((copied + 1))
      else
        printf '        ERROR: cp failed\n' >&2
        log ERROR "Copy failed: $src_file"
        errors=$((errors + 1))
      fi
      ;;

    m4p)
      # .m4p: DRM-protected; divert to Desktop or skip with warning
      if [[ "$divert_m4p" == true ]]; then
        out="$M4P_DIR/$rel"
        out_dir_m4p="$M4P_DIR/$(dirname "$rel")"

        if [[ -f "$out" ]]; then
          printf '%s SKIP (exists)  %s\n' "$prefix" "$out"
          log SKIP "Already exists: $out"
          skipped=$((skipped + 1))
          continue
        fi

        printf '%s DIVERT   %s\n        -> %s\n' "$prefix" "$src_file" "$out"

        if [[ "$dry_run" == true ]]; then
          log INFO "Dry-run divert: $src_file -> $out"
          diverted=$((diverted + 1))
          continue
        fi

        mkdir -p "$out_dir_m4p"

        if mv "$src_file" "$out"; then
          log OK "Diverted: $src_file -> $out"
          diverted=$((diverted + 1))
        else
          printf '        ERROR: mv failed\n' >&2
          log ERROR "Divert failed: $src_file"
          errors=$((errors + 1))
        fi
      else
        printf '%s SKIP (DRM)     %s\n' "$prefix" "$src_file"
        printf '        .m4p files are DRM-protected; use --divert-m4p to divert to %s\n' "$M4P_DIR"
        log SKIP "DRM-protected, skipped: $src_file"
        skipped=$((skipped + 1))
      fi
      ;;

    mp4|m4a)
      # .mp4/.m4a: convert to FLAC
      out="$tgt_base/${rel%.*}.flac"

      if [[ -f "$out" ]]; then
        printf '%s SKIP (exists)  %s\n' "$prefix" "$out"
        log SKIP "Already exists: $out"
        skipped=$((skipped + 1))
        continue
      fi

      # Audio stream check
      audio=$(ffprobe -v error -select_streams a \
        -show_entries stream=index \
        -of csv=p=0 "$src_file" 2>/dev/null)
      if [[ -z "$audio" ]]; then
        printf '%s SKIP (no audio) %s\n' "$prefix" "$src_file"
        log SKIP "No audio stream: $src_file"
        skipped=$((skipped + 1))
        continue
      fi

      printf '%s CONVERT  %s\n        -> %s\n' "$prefix" "$src_file" "$out"

      if [[ "$dry_run" == true ]]; then
        log INFO "Dry-run convert: $src_file -> $out"
        converted=$((converted + 1))
        continue
      fi

      mkdir -p "$out_dir"

      if ffmpeg -i "$src_file" -vn -acodec flac \
          -compression_level 12 \
          -map_metadata 0 \
          -loglevel error \
          "$out" 2>/tmp/music_convert_err; then
        log OK "$src_file -> $out"
        converted=$((converted + 1))
      else
        err_msg=$(cat /tmp/music_convert_err 2>/dev/null || true)
        printf '        ERROR: %s\n' "$err_msg" >&2
        log ERROR "Conversion failed: $src_file${err_msg:+  ($err_msg)}"
        errors=$((errors + 1))
      fi
      ;;
  esac
done

# ---------------------------------------------------------------------------
# Summary
# ---------------------------------------------------------------------------
summary="converted: $converted, copied: $copied, diverted: $diverted, skipped: $skipped, errors: $errors"
printf '\nDone — %s\n' "$summary"
log INFO "Run complete — $summary"

[[ $errors -gt 0 ]] && exit 1 || exit 0

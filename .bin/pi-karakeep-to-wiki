#!/usr/bin/env bash
# Karakeep sync + auto-ingest — Daily at 05:30
# 1. Syncs Karakeep bookmarks to kb/sources/web/
# 2. Detects new markdown files since last run
# 3. Runs wiki-ingest on new files
set -euo pipefail
source "${HOME}/.bin/pi-cron-common"

LOG_FILE="${LOG_DIR}/karakeep-to-wiki.log"

# Files used to coordinate sync -> ingest
CHANGED_FILE="${STATE_DIR}/karakeep-changed-files.txt"
PENDING_FILE="${STATE_DIR}/karakeep-pending-ingest.txt"

main() {
  echo "--- $(date '+%Y-%m-%d %H:%M:%S') ---"

  # Step 1: Sync Karakeep
  log_info "Step 1: Syncing Karakeep bookmarks..."
  bash "${HOME}/Obsidian/Notes/.pi/skills/_shared/scripts/karakeep-sync.sh"
  log_info "Karakeep sync complete"

  # Step 2: Build ingest queue from changed-files manifest + pending backlog
  local changed_files=()
  local pending_files=()

  if [ -f "$CHANGED_FILE" ]; then
    while IFS= read -r f; do
      [ -n "$f" ] && [ -f "$f" ] && changed_files+=("$f")
    done < "$CHANGED_FILE"
  fi

  if [ -f "$PENDING_FILE" ]; then
    while IFS= read -r f; do
      [ -n "$f" ] && [ -f "$f" ] && pending_files+=("$f")
    done < "$PENDING_FILE"
  fi

  log_info "Changed this sync: ${#changed_files[@]}"
  log_info "Pending from previous failures: ${#pending_files[@]}"

  local queue_file
  queue_file=$(mktemp)
  {
    printf '%s\n' "${pending_files[@]:-}"
    printf '%s\n' "${changed_files[@]:-}"
  } | sed '/^$/d' | sort -u > "$queue_file"

  local ingest_files=()
  while IFS= read -r f; do
    [ -n "$f" ] && ingest_files+=("$f")
  done < "$queue_file"
  rm -f "$queue_file"

  if [ ${#ingest_files[@]} -eq 0 ]; then
    log_info "No changed files to ingest"
    : > "$PENDING_FILE"
    return 0
  fi

  log_info "Files queued for ingest (${#ingest_files[@]}):"
  printf '  %s\n' "${ingest_files[@]}"

  local file_list
  file_list=$(printf '"%s" ' "${ingest_files[@]}")

  if pi_run "wiki-ingest" "$file_list"; then
    : > "$PENDING_FILE"
    log_info "Auto-ingest complete"
    qmd_refresh
  else
    printf '%s\n' "${ingest_files[@]}" > "$PENDING_FILE"
    log_error "Auto-ingest failed — queued ${#ingest_files[@]} file(s) for retry"
    return 1
  fi
}

main >> "$LOG_FILE" 2>&1

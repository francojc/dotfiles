#!/usr/bin/env bash
# Karakeep sync + auto-ingest — Daily at 05:30
# 1. Syncs Karakeep bookmarks to kb/sources/web/
# 2. Detects new markdown files since last run
# 3. Runs wiki-batch-ingest on new files
set -euo pipefail
source "${HOME}/.bin/pi-cron-common"

LOG_FILE="${LOG_DIR}/karakeep-to-wiki.log"

# Track last sync timestamp in a state file
STATE_FILE="${HOME}/.pi/state/karakeep-last-sync"
mkdir -p "$(dirname "$STATE_FILE")"

main() {
  echo "--- $(date '+%Y-%m-%d %H:%M:%S') ---"

  # Step 1: Sync Karakeep
  log_info "Step 1: Syncing Karakeep bookmarks..."
  bash "${HOME}/Obsidian/Notes/.pi/skills/_shared/scripts/karakeep-sync.sh"
  log_info "Karakeep sync complete"

  # Step 2: Find new files since last sync
  local last_sync
  if [ -f "$STATE_FILE" ]; then
    last_sync=$(cat "$STATE_FILE")
    log_info "Last sync: $last_sync"
  else
    last_sync="1970-01-01"
    log_info "No previous sync found — ingesting all files"
  fi

  # Find markdown files in kb/sources/web/ modified since last sync
  local new_files
  new_files=$(find "${HOME}/Obsidian/Notes/kb/sources/web/" -name "*.md" -newer "$STATE_FILE" 2>/dev/null | tr '\n' ' ')

  if [ -z "$new_files" ]; then
    log_info "No new files to ingest"
  else
    log_info "Found new files to ingest: $new_files"
    echo "$new_files" | xargs pi_run "wiki-batch-ingest"
    log_info "Auto-ingest complete"
  fi

  # Update last sync timestamp
  date +%Y-%m-%dT%H:%M:%S > "$STATE_FILE"
}

main >> "$LOG_FILE" 2>&1

# Shared config for Claude planning cron scripts
# Source this; do not execute directly.

source "${HOME}/.bin/common"

readonly VAULT_DIR="${HOME}/Obsidian/Notes"
readonly LOG_DIR="${VAULT_DIR}/.claude/logs"
readonly CLAUDE_TIMEOUT="${CLAUDE_TIMEOUT:-600}"  # 10 min default

# Run claude -p with standard cron flags
# Usage: claude_run <prompt>
claude_run() {
  local prompt="$1"
  cd "$VAULT_DIR"
  log_info "Starting: claude -p \"$prompt\""
  local start_time
  start_time=$(date +%s)

  claude -p "$prompt" --verbose --dangerously-skip-permissions \
    --strict-mcp-config &
  local pid=$!

  # Watchdog: kill claude if it exceeds the timeout
  (
    sleep "$CLAUDE_TIMEOUT"
    if kill -0 "$pid" 2>/dev/null; then
      log_error "Timed out after ${CLAUDE_TIMEOUT}s — killing pid $pid"
      kill "$pid" 2>/dev/null
    fi
  ) &
  local watchdog_pid=$!

  wait "$pid"
  local exit_code=$?

  # Clean up the watchdog if claude finished first
  # (kill + wait returns 143 from SIGTERM — suppress to avoid ERR trap)
  kill "$watchdog_pid" 2>/dev/null || true
  wait "$watchdog_pid" 2>/dev/null || true

  local elapsed=$(( $(date +%s) - start_time ))
  log_info "Finished in ${elapsed}s (exit $exit_code)"
  return $exit_code
}
